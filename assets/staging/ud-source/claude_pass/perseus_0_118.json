[
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@41",
    "text": "Te quoque magna manent regnis penetralia nostris:",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@43",
    "text": "Foliis tantum ne carmina manda, ne turbata uolent rapidis ludibria uentis;",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@44",
    "text": "ipsa canas oro. '",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@45",
    "text": "Finem dedit ore loquendi.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@46",
    "text": "At, Phoebi nondum patiens, immanis in antro bacchatur uates, magnum si pectore possit excussisse deum.",
    "entities": [
      {
        "text": "Phoebi",
        "label": "PERSON",
        "start": 4,
        "end": 10,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@50",
    "text": "Sed terrae grauiora manent.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@51",
    "text": "In regna Lauini Dardanidae uenient;",
    "entities": [
      {
        "text": "Lauini",
        "label": "LOC",
        "start": 9,
        "end": 15,
        "multi": false
      },
      {
        "text": "Dardanidae",
        "label": "NORP",
        "start": 16,
        "end": 26,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@52",
    "text": "mitte hanc de pectore curam;",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@53",
    "text": "sed non et uenisse uolent.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@55",
    "text": "Non Simois tibi, nec Xanthus, nec Dorica castra defuerint;",
    "entities": [
      {
        "text": "Simois",
        "label": "LOC",
        "start": 4,
        "end": 10,
        "multi": false
      },
      {
        "text": "Xanthus",
        "label": "LOC",
        "start": 21,
        "end": 28,
        "multi": false
      },
      {
        "text": "Dorica",
        "label": "NORP",
        "start": 34,
        "end": 40,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@56",
    "text": "alius Latio iam partus Achilles, natus et ipse dea;",
    "entities": [
      {
        "text": "Latio",
        "label": "LOC",
        "start": 6,
        "end": 11,
        "multi": false
      },
      {
        "text": "Achilles",
        "label": "PERSON",
        "start": 23,
        "end": 31,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@57",
    "text": "nec Teucris addita Iuno usquam aberit;",
    "entities": [
      {
        "text": "Teucris",
        "label": "NORP",
        "start": 4,
        "end": 11,
        "multi": false
      },
      {
        "text": "Iuno",
        "label": "PERSON",
        "start": 19,
        "end": 23,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@60",
    "text": "Tu ne cede malis, sed contra audentior ito, qua tua te Fortuna sinet.",
    "entities": [
      {
        "text": "Fortuna",
        "label": "PERSON",
        "start": 55,
        "end": 62,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@63",
    "text": "ea frena furenti concutit, et stimulos sub pectore uertit Apollo.",
    "entities": [
      {
        "text": "Apollo",
        "label": "PERSON",
        "start": 58,
        "end": 64,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@64",
    "text": "Ut primum cessit furor et rabida ora quierunt, incipit Aeneas heros:",
    "entities": [
      {
        "text": "Aeneas",
        "label": "PERSON",
        "start": 55,
        "end": 61,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@66",
    "text": "omnia praecepi atque animo me cum ante peregi.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@67",
    "text": "Unum oro.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@69",
    "text": "doceas iter et sacra ostia pandas.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@72",
    "text": "Quin, ut te supplex peterem et tua limina adirem, idem orans mandata dabat.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@78",
    "text": "noctes atque dies patet atri ianua Ditis;",
    "entities": [
      {
        "text": "Ditis",
        "label": "PERSON",
        "start": 35,
        "end": 40,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@80",
    "text": "Pauci, quos aequus amauit Iuppiter, aut ardens euexit ad aethera uirtus, dis geniti potuere.",
    "entities": [
      {
        "text": "Iuppiter",
        "label": "PERSON",
        "start": 26,
        "end": 34,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@83",
    "text": "Latet arbore opaca aureus et foliis et lento uimine ramus, Iunoni infernae dictus sacer;",
    "entities": [
      {
        "text": "Iunoni",
        "label": "PERSON",
        "start": 59,
        "end": 65,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@84",
    "text": "hunc tegit omnis lucus, et obscuris claudunt conuallibus umbrae.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@85",
    "text": "Sed non ante datur telluris operta subire, auricomos quam quis decerpserit arbore fetus.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@86",
    "text": "Hoc sibi pulchra suum ferri Proserpina munus instituit.",
    "entities": [
      {
        "text": "Proserpina",
        "label": "PERSON",
        "start": 28,
        "end": 38,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@87",
    "text": "Primo auulso non deficit alter aureus, et simili frondescit uirga metallo.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@88",
    "text": "Ergo alte uestiga oculis, et rite repertum carpe manu;",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@90",
    "text": "aliter non uiribus ullis uincere, nec duro poteris conuellere ferro.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@92",
    "text": "Sedibus hunc refer ante suis et conde sepulchro.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@93",
    "text": "Duc nigras pecudes;",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@94",
    "text": "ea prima piacula sunto:",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@95",
    "text": "sic demum lucos Stygis et regna inuia uiuis aspicies. '",
    "entities": [
      {
        "text": "Stygis",
        "label": "LOC",
        "start": 16,
        "end": 22,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@98",
    "text": "Cui fidus Achates it comes, et paribus curis uestigia figit.",
    "entities": [
      {
        "text": "Achates",
        "label": "PERSON",
        "start": 10,
        "end": 17,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@101",
    "text": "Hectoris hic magni fuerat comes, Hectora circum et lituo pugnas insignis obibat et hasta:",
    "entities": [
      {
        "text": "Hectoris",
        "label": "PERSON",
        "start": 0,
        "end": 8,
        "multi": false
      },
      {
        "text": "Hectora",
        "label": "PERSON",
        "start": 33,
        "end": 40,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@102",
    "text": "postquam illum uita uictor spoliauit Achilles, Dardanio Aeneae sese fortissimus heros addiderat socium, non inferiora secutus.",
    "entities": [
      {
        "text": "Achilles",
        "label": "PERSON",
        "start": 37,
        "end": 45,
        "multi": false
      },
      {
        "text": "Dardanio",
        "label": "NORP",
        "start": 47,
        "end": 55,
        "multi": false
      },
      {
        "text": "Aeneae",
        "label": "PERSON",
        "start": 56,
        "end": 62,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@103",
    "text": "Sed tum, forte caua dum personat aequora concha, demens, et cantu uocat in certamina diuos, aemulus exceptum Triton, si credere dignum est, inter saxa uirum spumosa inmerserat unda.",
    "entities": [
      {
        "text": "Triton",
        "label": "PERSON",
        "start": 109,
        "end": 115,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@104",
    "text": "Ergo omnes magno circum clamore fremebant, praecipue pius Aeneas.",
    "entities": [
      {
        "text": "Aeneas",
        "label": "PERSON",
        "start": 58,
        "end": 64,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@115",
    "text": "Sic effatus uestigia pressit, obseruans quae signa ferant, quo tendere pergant.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@116",
    "text": "Pascentes illae tantum prodire uolando, quantum acie possent oculi seruare sequentum.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@118",
    "text": "Quale solet siluis brumali frigore uiscum fronde uirere noua, quod non sua seminat arbos, et croceo fetu teretis circumdare truncos, talis erat species auri frondentis opaca ilice, sic leni crepitabat brattea uento.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@120",
    "text": "nec minus interea Misenum in litore Teucri flebant, et cineri ingrato suprema ferebant.",
    "entities": [
      {
        "text": "Misenum",
        "label": "PERSON",
        "start": 18,
        "end": 25,
        "multi": false
      },
      {
        "text": "Teucri",
        "label": "NORP",
        "start": 36,
        "end": 42,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@123",
    "text": "Fit gemitus.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@126",
    "text": "Congesta cremantur turea dona, dapes, fuso crateres oliuo.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@130",
    "text": "His actis, propere exsequitur praecepta Sibyllae.",
    "entities": [
      {
        "text": "Sibyllae",
        "label": "PERSON",
        "start": 40,
        "end": 48,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@132",
    "text": "talis sese halitus atris faucibus effundens supera ad conuexa ferebat:",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@133",
    "text": "unde locum Grai dixerunt nomine Aornon.",
    "entities": [
      {
        "text": "Grai",
        "label": "NORP",
        "start": 11,
        "end": 15,
        "multi": false
      },
      {
        "text": "Aornon",
        "label": "LOC",
        "start": 32,
        "end": 38,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@143",
    "text": "Tantum effata, furens antro se immisit aperto;",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@144",
    "text": "ille ducem haud timidis uadentem passibus aequat.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@159",
    "text": "Portitor has horrendus aquas et flumina seruat terribili squalore Charon, cui plurima mento canities inculta iacet;",
    "entities": [
      {
        "text": "Charon",
        "label": "PERSON",
        "start": 66,
        "end": 72,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@160",
    "text": "stant lumina flamma, sordidus ex umeris nodo dependet amictus.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@163",
    "text": "quam multa in siluis autumni frigore primo lapsa cadunt folia, aut ad terram gurgite ab alto quam multae glomerantur aues, ubi frigidus annus trans pontum fugat, et terris immittit apricis.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@173",
    "text": "Nec ripas datur horrendas et rauca fluenta transportare prius quam sedibus ossa quierunt.",
    "entities": []
  },
  {
    "sent_id": "phi0690.phi003.perseus-lat1.tb.xml@175",
    "text": "tum demum admissi stagna exoptata reuisunt. '",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@1",
    "text": "In noua fert animus mutatas dicere formas corpora;",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@2",
    "text": "di, coeptis ( nam uos mutastis et illas ) adspirate meis prima que ab origine mundi ad mea perpetuum deducite tempora carmen.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@5",
    "text": "Quae pater ut summa uidit Saturnius arce, ingemit et, facto nondum uulgata recenti, foeda Lycaoniae referens conuiuia mensae, ingentes animo et dignas Ioue concipit iras, concilium que uocat:",
    "entities": [
      {
        "text": "Saturnius",
        "label": "PERSON",
        "start": 26,
        "end": 35,
        "multi": false
      },
      {
        "text": "Lycaoniae",
        "label": "NORP",
        "start": 90,
        "end": 99,
        "multi": false
      },
      {
        "text": "Ioue",
        "label": "PERSON",
        "start": 151,
        "end": 155,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@6",
    "text": "tenuit mora nulla uocatos.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@8",
    "text": "lactea nomen habet, candore notabilis ipso:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@11",
    "text": "hac parte potentes caelicolae clari que suos posuere Penates.",
    "entities": [
      {
        "text": "Penates",
        "label": "PERSON",
        "start": 53,
        "end": 60,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@12",
    "text": "Hic locus est, quem, si uerbis audacia detur, haud timeam magni dixisse Palatia caeli.",
    "entities": [
      {
        "text": "Palatia",
        "label": "LOC",
        "start": 72,
        "end": 79,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@13",
    "text": "Ergo ubi marmoreo superi sedere recessu, celsior ipse loco sceptro que innixus eburno terrificam capitis concussit ter que quater que caesariem, cum qua terram, mare, sidera mouit.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@14",
    "text": "Talibus inde modis ora indignantia soluit:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@15",
    "text": "' Non ego pro mundi regno magis anxius illa tempestate fui, qua centum quisque parabat inicere anguipedum captiuo bracchia caelo.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@16",
    "text": "Nam quamquam ferus hostis erat, tamen illud ab uno corpore et ex una pendebat origine bellum.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@17",
    "text": "Nunc mihi, qua totum Nereus circumsonat orbem, perdendum est mortale genus:",
    "entities": [
      {
        "text": "Nereus",
        "label": "PERSON",
        "start": 21,
        "end": 27,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@18",
    "text": "per flumina iuro infera, sub terras Stygio labentia luco!",
    "entities": [
      {
        "text": "Stygio",
        "label": "LOC",
        "start": 36,
        "end": 42,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@19",
    "text": "cuncta prius temptata:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@20",
    "text": "sed inmedicabile corpus ense recidendum est, ne pars sincera trahatur.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@22",
    "text": "quos quoniam caeli nondum dignamur honore, quas dedimus certe terras habitare sinamus.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@23",
    "text": "An satis, o superi, tutos fore creditis illos, cum mihi, qui fulmen, qui uos habeo que rego que , struxerit insidias notus feritate Lycaon? '",
    "entities": [
      {
        "text": "Lycaon",
        "label": "PERSON",
        "start": 132,
        "end": 138,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@24",
    "text": "Confremuere omnes studiis que ardentibus ausum talia deposcunt.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@29",
    "text": "Quod tamen admissum, quae sit uindicta, docebo.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@30",
    "text": "Contigerat nostras infamia temporis aures;",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@33",
    "text": "minor fuit ipsa infamia uero.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@34",
    "text": "Maenala transieram latebris horrenda ferarum et cum Cyllene gelidi pineta Lycaei:",
    "entities": [
      {
        "text": "Maenala",
        "label": "LOC",
        "start": 0,
        "end": 7,
        "multi": false
      },
      {
        "text": "Cyllene",
        "label": "LOC",
        "start": 52,
        "end": 59,
        "multi": false
      },
      {
        "text": "Lycaei",
        "label": "LOC",
        "start": 74,
        "end": 80,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@35",
    "text": "Arcadis hinc sedes et inhospita tecta tyranni ingredior, traherent cum sera crepuscula noctem.",
    "entities": [
      {
        "text": "Arcadis",
        "label": "NORP",
        "start": 0,
        "end": 7,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@36",
    "text": "Signa dedi uenisse deum, uulgus que precari coepi:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@37",
    "text": "inridet primo pia uota Lycaon, mox ait ' experiar deus hic, discrimine aperto, an sit mortalis.",
    "entities": [
      {
        "text": "Lycaon",
        "label": "PERSON",
        "start": 23,
        "end": 29,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@38",
    "text": "Nec erit dubitabile uerum.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@39",
    "text": "Nocte grauem somno necopina perdere morte me parat:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@40",
    "text": "haec illi placet experientia ueri.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@41",
    "text": "Nec contentus eo est:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@43",
    "text": "Quod simul inposuit mensis, ego uindice flamma in domino dignos euerti tecta Penates.",
    "entities": [
      {
        "text": "Penates",
        "label": "PERSON",
        "start": 77,
        "end": 84,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@44",
    "text": "Territus ipse fugit, nactus que silentia ruris exululat frustra que loqui conatur:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@45",
    "text": "ab ipso conligit os rabiem, solitae que cupidine caedis uertitur in pecudes et nunc quoque sanguine gaudet.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@47",
    "text": "fit lupus et ueteris seruat uestigia formae.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@49",
    "text": "Occidit una domus.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@50",
    "text": "Sed non domus una perire digna fuit:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@51",
    "text": "qua terra patet, fera regnat Erinys.",
    "entities": [
      {
        "text": "Erinys",
        "label": "PERSON",
        "start": 29,
        "end": 35,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@52",
    "text": "In facinus iurasse putes.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@53",
    "text": "Dent ocius omnes quas meruere pati ( sic stat sententia ) poenas.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@56",
    "text": "Talia quaerentes ( sibi enim fore cetera curae ) rex superum trepidare uetat subolem que priori dissimilem populo promittit origine mira.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@58",
    "text": "sed timuit, ne forte sacer tot ab ignibus aether conciperet flammas longus que ardesceret axis:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@60",
    "text": "Tela reponuntur manibus fabricata Cyclopum:",
    "entities": [
      {
        "text": "Cyclopum",
        "label": "PERSON",
        "start": 34,
        "end": 42,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@61",
    "text": "poena placet diuersa, genus mortale sub undis perdere et ex omni nimbos demittere caelo.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@62",
    "text": "Protinus Aeoliis Aquilonem claudit in antris et quaecumque fugant inductas flamina nubes emittit que Notum.",
    "entities": [
      {
        "text": "Aeoliis",
        "label": "LOC",
        "start": 9,
        "end": 16,
        "multi": false
      },
      {
        "text": "Aquilonem",
        "label": "PERSON",
        "start": 17,
        "end": 26,
        "multi": false
      },
      {
        "text": "Notum",
        "label": "PERSON",
        "start": 101,
        "end": 106,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@63",
    "text": "Madidis Notus euolat alis, terribilem picea tectus caligine uultum:",
    "entities": [
      {
        "text": "Notus",
        "label": "PERSON",
        "start": 8,
        "end": 13,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@65",
    "text": "fronte sedent nebulae, rorant pennae que sinus que .",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@66",
    "text": "Ut que manu late pendentia nubila pressit, fit fragor:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@67",
    "text": "hinc densi funduntur ab aethere nimbi.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@69",
    "text": "Sternuntur segetes et deplorata coloni uota iacent, longi que perit labor inritus anni.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@70",
    "text": "Nec caelo contenta suo est Iouis ira, sed illum caeruleus frater iuuat auxiliaribus undis.",
    "entities": [
      {
        "text": "Iouis",
        "label": "PERSON",
        "start": 27,
        "end": 32,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@71",
    "text": "Conuocat hic amnes.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@73",
    "text": "Uires effundite uestras:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@76",
    "text": "Iusserat;",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@77",
    "text": "hi redeunt ac fontibus ora relaxant et defrenato uoluuntur in aequora cursu.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@78",
    "text": "Ipse tridente suo terram percussit:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@79",
    "text": "at illa intremuit motu que uias patefecit aquarum.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@80",
    "text": "Exspatiata ruunt per apertos flumina campos cumque satis arbusta simul pecudes que uiros que tecta que cumque suis rapiunt penetralia sacris.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@81",
    "text": "Iamque mare et tellus nullum discrimen habebant:",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@82",
    "text": "omnia pontus erant;",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@83",
    "text": "deerant quoque litora ponto.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@85",
    "text": "Figitur in uiridi, si fors tulit, ancora prato, aut subiecta terunt curuae uineta carinae;",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@86",
    "text": "et, modo qua graciles gramen carpsere capellae, nunc ibi deformes ponunt sua corpora phocae.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@89",
    "text": "Quaesitis que diu terris, ubi sistere possit, in mare lassatis uolucris uaga decidit alis.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@90",
    "text": "Obruerat tumulos inmensa licentia ponti, pulsabant que noui montana cacumina fluctus.",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@91",
    "text": "Maxima pars unda rapitur;",
    "entities": []
  },
  {
    "sent_id": "phi0959.phi006.perseus-lat1.tb.xml@92",
    "text": "quibus unda pepercit, illos longa domant inopi ieiunia uictu.",
    "entities": []
  }
]