        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@702",
    "text": "Uicit scilicet et Iphigeniam, filiam suam, Achilli dedit uxorem.",
    "entities": [
      {
        "text": "Iphigeniam",
        "label": "PERSON",
        "start": 18,
        "end": 28,
        "multi": false
      },
      {
        "text": "Achilli",
        "label": "PERSON",
        "start": 43,
        "end": 50,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@708",
    "text": "Consternatus ego exsurrexi et timui, ne per tectum petauristarius aliquis descenderet.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@709",
    "text": "Nec minus reliqui conuiuae mirantes erexere uultus, expectantes quid noui de caelo nuntiaretur.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@710",
    "text": "Ecce autem diductis lacunaribus subito circulus ingens, de cupa uidelicet grandi excussus, demittitur, cuius per totum orbem coronae aureae cum alabastris unguenti pendebant.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@713",
    "text": "Auidius ad pompam manus porreximus, et repente noua ludorum remissio hilaritatem hic refecit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@719",
    "text": "Nos etiam ueram imaginem ipsius Trimalchionis, cum iam omnes basiarent, erubuimus praeterire.",
    "entities": [
      {
        "text": "Trimalchionis",
        "label": "PERSON",
        "start": 32,
        "end": 45,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@721",
    "text": "nescio quid nunc taces nec muttis.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@724",
    "text": "Itaque hilaria mera sint, etsi timeo istos scholasticos, ne me rideant.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@725",
    "text": "Uiderint:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@726",
    "text": "narrabo tamen:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@727",
    "text": "quid enim mihi aufert, qui ridet?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@731",
    "text": "nune Gauillae domus est.",
    "entities": [
      {
        "text": "Gauillae",
        "label": "PERSON",
