        "end": 23,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@700",
    "text": "Agamemnon illam rapuit et Dianae ceruam subiecit.",
    "entities": [
      {
