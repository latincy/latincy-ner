      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@701",
    "text": "Ita nunc Homeros dicit, quemadmodum inter se pugnent Troiani et Parentini.",
    "entities": [
      {
        "text": "Homeros",
        "label": "PERSON",
        "start": 9,
        "end": 16,
        "multi": false
      },
      {
