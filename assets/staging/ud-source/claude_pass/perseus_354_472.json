[
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@241",
    "text": "Modo, modo me appellauit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@242",
    "text": "Uideor mihi cum illo loqui.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@244",
    "text": "Utres inflati ambulamus.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@247",
    "text": "Quinque dies aquam in os suum non coniecit, non micam panis.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@248",
    "text": "Tamen abiit ad plures.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@255",
    "text": "Neminem nihil boni facere oportet;",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@260",
    "text": "Ille habet, quod sibi debebatur:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@261",
    "text": "honeste uixit, honeste obiit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@262",
    "text": "Quid habet quod queratur?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@265",
    "text": "Puto mehercules illum reliquisse lida centum, et omnia in nummis habuit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@266",
    "text": "De re tamen ego uerum dicam, qui linguam caninam comedi:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@270",
    "text": "uendidit enim uinum, quanti ipse uoluit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@272",
    "text": "Et ille stips, dum fratri suo irascitur, nescio cui terrae filio patrimonium elegauit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@273",
    "text": "Longe fugit, quisquis suos fugit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@274",
    "text": "Habuit autem oricularios seruos, qui illum pessum dederunt.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@275",
    "text": "Nunquam autem recte faciet, qui cito credit, utique homo negotians.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@279",
    "text": "Facile est autem, ubi omnia quadrata currunt.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@280",
    "text": "Et quot putas illum annos se cum tulisse?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@283",
    "text": "Noueram hominem olim oliorum et adhuc salax erat.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@284",
    "text": "Non mehercules illum puto in domo canem reliquisse.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@287",
    "text": "Haec Phileros dixit, illa Ganymedes:",
    "entities": [
      {
        "text": "Phileros",
        "label": "PERSON",
        "start": 5,
        "end": 13,
        "multi": false
      },
      {
        "text": "Ganymedes",
        "label": "PERSON",
        "start": 26,
        "end": 35,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@289",
    "text": "Non mehercules hodie buccam panis inuenire potui.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@290",
    "text": "Et quomodo siccitas perseuerat.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@292",
    "text": "Aediles male eueniat, qui cum pistoribus colludunt ' Serua me, seruabo te. '",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@293",
    "text": "Itaque populus minutus laborat;",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@296",
    "text": "Illud erat uiuere.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@300",
    "text": "Is quacunque ibat, terram adurebat.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@303",
    "text": "Cum ageret porro in foro, sic illius uox crescebat tanquam tuba.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@306",
    "text": "Itaque illo tempore annona pro luto erat, Asse panem quem emisses, non potuisses cum altera deuorare.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@307",
    "text": "Nunc oculum bublum uidi maiorem.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@309",
    "text": "Haec colonia retrouersus crescit tanquam coda uituli.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@310",
    "text": "Sed quare nos habemus aedilem trium cauniarum, qui sibi mauult assem quam uitam nostram?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@311",
    "text": "Itaque domi gaudet, plus in die nummorum accipit, quam alter patrimonium habet.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@312",
    "text": "Iam scio, unde acceperit denarios mille aureos.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@313",
    "text": "Sed si nos coleos haberemus, non tantum sibi placeret.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@314",
    "text": "Nunc populus est domi leones, foras uulpes.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@315",
    "text": "Quod ad me attinet, iam pannos meos comedi, et si perseuerat haec annona, casulas meas uendam.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@317",
    "text": "Ita meos fruniscar, ut ego puto omnia illa a diibus fieri.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@319",
    "text": "Antea stolatae ibant nudis pedibus in cliuum, passis capillis, mentibus puris, et Iouem aquam exorabant.",
    "entities": [
      {
        "text": "Iouem",
        "label": "PERSON",
        "start": 82,
        "end": 87,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@320",
    "text": "Itaque statim urceatim plouebat:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@321",
    "text": "aut ne tu aut nunquam:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@322",
    "text": "et omnes redibant udi tanquam mures.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@323",
    "text": "Itaque dii pedes lanatos habent, quia nos religiosi non sumus.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@327",
    "text": "uarium porcum perdiderat.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@329",
    "text": "sic uita truditur.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@330",
    "text": "Non mehercules patria melior dici potest, si homines haberet.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@336",
    "text": "Et Titus noster magnum animum habet et est ealdicerebrius:",
    "entities": [
      {
        "text": "Titus",
        "label": "PERSON",
        "start": 3,
        "end": 8,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@340",
    "text": "Et habet unde:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@342",
    "text": "Ut quadringenta impendat, non sentiet patrimonium illius, et sempiterno nominabitur.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@344",
    "text": "Uidebis populi rixam inter zelotypos et amasiunculos.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@345",
    "text": "Glyco autem, sestertiarius homo, dispensatorem ad bestias dedit.",
    "entities": [
      {
        "text": "Glyco",
        "label": "PERSON",
        "start": 0,
        "end": 5,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@346",
    "text": "Hoc est se ipsum traducere.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@348",
    "text": "Magis illa matella digna fuit quam taurus iactaret.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@349",
    "text": "Sed qui asinum non potest, stratum caedit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@350",
    "text": "Quid autem Glyco putabat Hermogenis filicem unquam bonum exitum facturam?",
    "entities": [
      {
        "text": "Glyco",
        "label": "PERSON",
        "start": 11,
        "end": 16,
        "multi": false
      },
      {
        "text": "Hermogenis",
        "label": "PERSON",
        "start": 25,
        "end": 35,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@351",
    "text": "Ille miluo uolanti poterat ungues resecare;",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@352",
    "text": "colubra restem non parit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@353",
    "text": "Glyco, Glyco dedit suas;",
    "entities": [
      {
        "text": "Glyco",
        "label": "PERSON",
        "start": 0,
        "end": 5,
        "multi": true
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@354",
    "text": "itaque quamdiu uixerit, habebit stigmam, nec illam nisi Orcus delebit.",
    "entities": [
      {
        "text": "Orcus",
        "label": "PERSON",
        "start": 56,
        "end": 61,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@355",
    "text": "Sed sibi quisque peccat.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@357",
    "text": "Quod si hoc fecerit, eripiat Norbano totum fauorem.",
    "entities": [
      {
        "text": "Norbano",
        "label": "PERSON",
        "start": 29,
        "end": 36,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@358",
    "text": "Scias oportet plenis uelis hunc uinciturum.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@359",
    "text": "Et reuera, quid ille nobis boni fecit?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@360",
    "text": "Dedit gladiatores sestertiarios iam decrepitos, quos si sufflasses, cecidissent;",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@361",
    "text": "iam meliores bestiarios uidi.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@368",
    "text": "et ego tibi plodo.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@369",
    "text": "Computa, et tibi plus do quam accepi.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@370",
    "text": "Manus manum lauat.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@371",
    "text": "Uideris mihi, Agamemnon, dicere:",
    "entities": [
      {
        "text": "Agamemnon",
        "label": "PERSON",
        "start": 14,
        "end": 23,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@374",
    "text": "Non es nostrae fasciae, et ideo pauperorum uerba derides.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@375",
    "text": "Scimus te prae litteras fatuum esse.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@377",
    "text": "aliqua die te persuadeam, ut ad uillam uenias et uideas casulas nostras?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@378",
    "text": "Inueniemus quod manducemus, pullum, oua:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@380",
    "text": "inueniemus ergo unde saturi fiamus.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@381",
    "text": "Et iam tibi discipulus crescit cicaro meus.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@382",
    "text": "Iam quattuor partis dicit;",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@383",
    "text": "si uixerit, habebis ad latus seruulum.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@385",
    "text": "Ingeniosus est et bono filo, etiam si in aues morbosus est.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@386",
    "text": "Ego illi iam tres cardeles occidi, et dixi quod mustella comedit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@387",
    "text": "Inuenit tamen alias nenias, et libentissime pingit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@390",
    "text": "Itaque feriatis diebus solet domum uenire, et quicquid dederis, contentus est.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@391",
    "text": "Emi ergo nunc puero aliquot libra rubricata, quia uolo illum ad domusionem aliquid de iure gustare.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@392",
    "text": "Habet haec res panem.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@394",
    "text": "Quod si resilient, destinaui illum artificii docere, aut tonstreinum aut praeconem aut certe causidicum, quod illi auferre non possit nisi Orcus.",
    "entities": [
      {
        "text": "Orcus",
        "label": "PERSON",
        "start": 139,
        "end": 144,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@395",
    "text": "Ideo illi cotidie clamo:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@397",
    "text": "Uides Phileronem causidicum:",
    "entities": [
      {
        "text": "Phileronem",
        "label": "PERSON",
        "start": 6,
        "end": 16,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@398",
    "text": "si non didicisset, hodie famem a labris non abigeret.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@399",
    "text": "Modo, modo collo suocircumferebat onera uenalia, nunc etiam aduersus Norbanum se extendit.",
    "entities": [
      {
        "text": "Norbanum",
        "label": "PERSON",
        "start": 69,
        "end": 77,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@401",
    "text": "Eiusmodi fabulae uibrabant, cum Trimalchio intrauit et detersa fronte unguento manus lauit spatio que minimo interposito ' Ignoscite mihi ' inquit ' amici, multis iam diebus uenter mihi non respondit.",
    "entities": [
      {
        "text": "Trimalchio",
        "label": "PERSON",
        "start": 32,
        "end": 42,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@402",
    "text": "Nec medici se inueniunt.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@403",
    "text": "Profuit mihi tamen malicorium et taeda ex aceto.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@404",
    "text": "Spero tamen, iamueterem pudorem sibi imponet.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@405",
    "text": "Alioquin circa stomachum mihi sonat, putes taurum.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@408",
    "text": "Ego nullum puto tam magnum tormentum esse quam continere.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@409",
    "text": "Hoc solum uetare ne Iouis potest.",
    "entities": [
      {
        "text": "Iouis",
        "label": "PERSON",
        "start": 20,
        "end": 25,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@410",
    "text": "Rides, Fortunata, quae soles me nocte desomnem facere?",
    "entities": [
      {
        "text": "Fortunata",
        "label": "PERSON",
        "start": 7,
        "end": 16,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@416",
    "text": "Gratias agimus liberalitati indulgentiae que eius, et subinde castigamus crebris potiunculis risum.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@417",
    "text": "Nec adhuc sciebamus nos in medio lautitiarum, quod aiunt, cliuo laborare.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@420",
    "text": "gallum enim gallinaceum, penthiacum et eiusmodi nenias rustici faciunt:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@429",
    "text": "uos illud oportet bonum faciatis.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@430",
    "text": "Deorum beneficio non emo, sed nunc quicquid ad saliuam facit, in suburbano nascitur eo, quod ego adhuc non noui.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@431",
    "text": "Dicitur confine esse Tarraciniensibus et Tarentinis.",
    "entities": [
      {
        "text": "Tarraciniensibus",
        "label": "NORP",
        "start": 21,
        "end": 37,
        "multi": false
      },
      {
        "text": "Tarentinis",
        "label": "NORP",
        "start": 41,
        "end": 51,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@432",
    "text": "Nunc coniungere agellis Siciliam uolo, ut cum Africam libuerit ire, per meos fines nauigem.",
    "entities": [
      {
        "text": "Siciliam",
        "label": "LOC",
        "start": 24,
        "end": 32,
        "multi": false
      },
      {
        "text": "Africam",
        "label": "LOC",
        "start": 46,
        "end": 53,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@434",
    "text": "Ego etiam si causas non ago, in domusionem tamen litteras didici.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@435",
    "text": "Et ne me putes studia fastiditum, II bybliothecas habeo, unam Graecam, alteram Latinam.",
    "entities": [
      {
        "text": "Graecam",
        "label": "NORP",
        "start": 62,
        "end": 69,
        "multi": false
      },
      {
        "text": "Latinam",
        "label": "NORP",
        "start": 79,
        "end": 86,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@443",
    "text": "Solebam haec ego puer apud Homerum legere.",
    "entities": [
      {
        "text": "Homerum",
        "label": "PERSON",
        "start": 27,
        "end": 34,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@445",
    "text": "respondebat illa:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@446",
    "text": "Nondum efflauerat omnia, cum repositorium cum sue ingenti mensam occupauit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@458",
    "text": "Deprecari tamen omnes coepi et dicere:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@460",
    "text": "rogamus, mittas;",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@463",
    "text": "aliquis obliuisceretur porcum exinterare?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@466",
    "text": "Recepta cocus tunica cultrum arripuit porci que uentrem hinec atque illinc timida manu secuit.",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@470",
    "text": "Quam cum Agamemnon propius consideraret, ait Trimalchio:",
    "entities": [
      {
        "text": "Agamemnon",
        "label": "PERSON",
        "start": 9,
        "end": 18,
        "multi": false
      },
      {
        "text": "Trimalchio",
        "label": "PERSON",
        "start": 45,
        "end": 55,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@472",
    "text": "Expectabam, ut pro reliqua insolentia diceret sibi uasa Corintho afferri.",
    "entities": [
      {
        "text": "Corintho",
        "label": "LOC",
        "start": 56,
        "end": 64,
        "multi": false
      }
    ]
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@473",
    "text": "Sed ille melius:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@476",
    "text": "Quid est autem Corintheum, nisi quis Corinthum habet?",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@481",
    "text": "Ignoscetis mihi, quod dixero:",
    "entities": []
  },
  {
    "sent_id": "phi0972.phi001.perseus-lat1.xml@482",
    "text": "ego malo mihi uitrea, certe non olunt.",
    "entities": []
  }
]