        },
        {
          "start": 7,
          "end": 17,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "In ludis litterariis filii principum Britannicorum linguae Latinae operam dabant.",
      "spans": [
        {
          "start": 37,
          "end": 50,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Itaque Britanni iram iniuriasque suas paulatim oblivioni dabant.",
