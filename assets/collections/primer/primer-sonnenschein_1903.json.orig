        },
        {
          "start": 96,
          "end": 104,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Sed quid inhumanius, quid saevius est quam bellum?",
      "spans": []
    },
    {
      "text": "Atque nulli hostes in bello crudeliores fuerunt quam Romani.",
      "spans": [
        {
          "start": 53,
          "end": 59,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Nihil minus clemens erat quam hostes debellatos in servitutem deportare.",
      "spans": []
    },
    {
      "text": "Nam mors pulchra minus misera est quam servitus.",
      "spans": []
    },
    {
      "text": "Omnibus hominibus vita cara est;",
      "spans": []
    },
    {
      "text": "sed viris liberis libertas carior est quam vita.",
      "spans": []
    },
    {
      "text": "Atque nulli homines unquam acriores defensores libertatis suae fuerunt quam Britanni.",
      "spans": [
        {
          "start": 76,
          "end": 84,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Nihil pulchrius existimabant quam libertatem, nihil miserius quam servitutem ».",
      "spans": []
    },
    {
      "text": "« Omnia bella saeva et inhumana sunt.",
      "spans": []
    },
    {
      "text": "Omnium autem bellorum saevissima et inhumanissima fuerunt bella illa temporibus antiquis contra gentes barbaras pugnata.",
      "spans": []
    },
    {
      "text": "Romani hostes crudelissimi plerumque fuerunt.",
      "spans": [
        {
          "start": 0,
          "end": 6,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sed quid utilius fuit toti orbi terrarum quam imperium Romanum?",
      "spans": [
        {
          "start": 55,
          "end": 62,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Et imperio Romano nullum maius periculum erat quam rebelliones populorum barbarorum.",
      "spans": [
        {
          "start": 11,
          "end": 17,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Homines feros et inhumanos a studio bellandi ad vitam humaniorem et ad litteras, artes, scientias revocavit.",
      "spans": []
    },
    {
      "text": "Romani Britanniam viis optimis et aedificiis pulcherrimis celeberrimisque, templis, basilicis, foris, villis, ludis litterariis, ornaverunt.",
