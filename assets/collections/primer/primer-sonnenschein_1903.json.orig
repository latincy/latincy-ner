        },
        {
          "start": 78,
          "end": 85,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "« sed si testimonium eius verum est, nullus victor Romanus humanior, nullus clementior fuit quam Iulius Agricola.",
      "spans": [
        {
          "start": 51,
          "end": 58,
          "label": "NORP"
        },
        {
          "start": 97,
          "end": 112,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Nulla autem provincia turbulentior fuerat quam Britannia.",
      "spans": [
        {
          "start": 47,
          "end": 56,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Nulli hostes Romanorum fortiores, nulli audaciores fuerant quam Britanni et Caledones et gentes Cambriae.",
      "spans": [
        {
          "start": 13,
          "end": 22,
          "label": "NORP"
        },
