          "start": 26,
          "end": 35,
          "label": "NORP"
        },
        {
          "start": 68,
          "end": 77,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Nam hi iustum proelium tolerare non poterant.",
      "spans": []
