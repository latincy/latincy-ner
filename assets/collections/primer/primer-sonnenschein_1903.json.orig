    },
    {
      "text": "Tum custodem valere iubemus, et ad cenam properamus.",
      "spans": []
    },
    {
      "text": "Sed vos mihi respondete.",
      "spans": []
    },
    {
      "text": "nihil habuimus respondere.",
      "spans": []
    },
    {
      "text": "nos nihil respondimus.",
      "spans": []
    },
    {
      "text": "Nam anno quingentesimo nonagesimo septimo post Christum natum Gregorius Primus, pontifex Romanus, Augustinum notitiam Dei veri in Anglia docere iusserat.",
      "spans": [
        {
          "start": 47,
          "end": 55,
          "label": "PERSON"
        },
        {
          "start": 62,
          "end": 71,
          "label": "PERSON"
        },
        {
          "start": 89,
          "end": 96,
          "label": "LOC"
        },
        {
          "start": 98,
          "end": 108,
          "label": "PERSON"
        },
        {
          "start": 130,
          "end": 136,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Itaque Augustinus ex Gallia in Britanniam navigavit, et navem suam ad insulam Tanatim applicavit.",
      "spans": [
        {
          "start": 7,
          "end": 17,
          "label": "PERSON"
        },
        {
          "start": 21,
          "end": 27,
          "label": "LOC"
        },
        {
          "start": 31,
          "end": 41,
          "label": "LOC"
        },
        {
          "start": 78,
          "end": 85,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Eo tempore Aedilberctus rex Cantii erat, qui uxorem Christianam, nomine Berctam, habebat, filiam regis Francorum.",
      "spans": [
        {
          "start": 11,
          "end": 23,
          "label": "PERSON"
        },
        {
          "start": 28,
          "end": 34,
          "label": "LOC"
        },
        {
          "start": 52,
          "end": 63,
          "label": "NORP"
        },
        {
          "start": 72,
          "end": 79,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Tum amita mea:",
      "spans": []
    },
    {
      "text": "Vel, ut non nulli libri historici affirmant, Christiani ad ipsos muros Castelli Rutupini navem suam applicaverant, et per fenestram castelli cum rege sermonem habuerunt.",
      "spans": [
        {
          "start": 45,
          "end": 55,
          "label": "NORP"
        },
        {
          "start": 71,
          "end": 88,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Nam eo tempore aqua portus Rutupini usque ad muros castelli pertinebat.",
      "spans": [
        {
          "start": 27,
          "end": 35,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Rex Christianis in hunc modum respondisse narratur.",
      "spans": [
        {
          "start": 4,
          "end": 15,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "‘Pulchra sunt verba et promissa vestra;",
      "spans": []
    },
    {
      "text": "sed nova sunt et incerta;",
      "spans": []
    },
    {
      "text": "nec deos antiquos, quos per multos annos ego et populus meus adoravimus, oblivioni dare possumus.",
      "spans": []
    },
    {
      "text": "Sed, quia ex terra peregrina huc cursum tenuistis, et in animo habetis ea docere quae vera esse existimatis, non prohibebo vos in regno meo manere et notitiam Dei vestri docere.",
      "spans": []
    },
    {
      "text": "Post principatum Neronis multi Christiani in imperio Romano fuerunt;",
      "spans": [
        {
          "start": 17,
          "end": 24,
          "label": "PERSON"
        },
        {
          "start": 31,
          "end": 41,
          "label": "LOC"
        },
        {
          "start": 53,
          "end": 59,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "nam anno primo et sexagesimo post Christum natum Sanctus Paulus Romam captivus deportatus est.",
      "spans": [
        {
          "start": 34,
          "end": 42,
          "label": "PERSON"
        },
        {
          "start": 49,
          "end": 63,
          "label": "PERSON"
        },
        {
          "start": 64,
          "end": 69,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Et uxor illius Auli Plautii, qui iam aetate principis Claudii Britanniae praefuit, Christiana fuisse existimatur.",
      "spans": [
        {
          "start": 15,
          "end": 27,
          "label": "PERSON"
        },
        {
          "start": 54,
          "end": 61,
          "label": "PERSON"
        },
        {
          "start": 62,
          "end": 72,
          "label": "LOC"
        },
        {
          "start": 83,
          "end": 93,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Nam ‘superstitionis peregrinae’ accusata est.",
      "spans": []
    },
    {
      "text": "Nomen ei fuit Pomponiae Graecinae.",
      "spans": [
        {
          "start": 14,
          "end": 33,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Sed Angli et Saxones, qui multos deos adorabant, basilicas Christianas plerumque deleverunt.",
      "spans": [
        {
          "start": 4,
          "end": 9,
          "label": "NORP"
        },
        {
          "start": 13,
          "end": 20,
          "label": "NORP"
        },
        {
          "start": 59,
          "end": 70,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Basilica autem Sancti Martini, quae Duroverni erat, non omnino deleta erat.",
      "spans": [
        {
          "start": 15,
          "end": 29,
          "label": "PERSON"
        },
        {
          "start": 36,
          "end": 45,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Durovernum igitur intraverunt nuntii illi verbi divini, crucem argenteam et simulacrum Christi in manibus tenentes, et carmen sacrum cantantes:",
      "spans": [
        {
          "start": 0,
          "end": 10,
          "label": "LOC"
        },
        {
          "start": 87,
          "end": 94,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "‘Iram tuam ab hac urbe et a domo tua sancta remove, o Deus;",
      "spans": []
    },
    {
      "text": "quia peccavimus:",
      "spans": []
    },
    {
      "text": "alleluia!’",
      "spans": []
    },
    {
      "text": "Et amita mea:",
      "spans": []
    },
    {
      "text": "Nam multis annis ante in foro Romano quondam fuit, cum pueros nonnullos facie pulchra, oculis caeruleis, capillis flavis vidit.",
      "spans": [
        {
          "start": 30,
          "end": 36,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Misericordia commotus est:",
      "spans": []
    },
    {
      "text": "nam illi pueri servi erant et venum dabantur.",
      "spans": []
    },
    {
      "text": "Itaque mercatores, quorum in manu pueri erant, sic interrogavit:",
      "spans": []
    },
    {
      "text": "Responderunt eos esse Anglos.",
      "spans": [
        {
          "start": 22,
          "end": 28,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "non Anglos sed Angelos eos vocari oportet.",
      "spans": [
        {
          "start": 4,
          "end": 10,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Intra semihoram vehiculum paratum erat, et in viam nos dedimus.",
      "spans": []
    },
    {
      "text": "Dum in vehiculo sedebamus, muros castelli luna plena illustratos vidimus.",
      "spans": []
    },
    {
      "text": "Pulchrum erat spectaculum.",
      "spans": []
    },
    {
      "text": "Mox domi eramus.",
      "spans": []
    },
    {
      "text": "Nos pueri longo die fatigati et semisomni eramus.",
      "spans": []
    },
    {
      "text": "Ea nocte Marcus et Alexander apud nos manserunt.",
      "spans": [
        {
          "start": 9,
          "end": 15,
          "label": "PERSON"
        },
        {
          "start": 19,
          "end": 28,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Postridie Dubras redambulaverunt.",
      "spans": [
        {
          "start": 10,
          "end": 16,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Hodie iam quinque dies post Idus Septembres elapsi sunt, et dies ille ater appropinquat qui ultimus feriarum erit.",
      "spans": []
    },
    {
      "text": "Omnium dierum ille tristissimus est qui finis est feriarum.",
      "spans": []
    },
    {
      "text": "Intra paucos dies patruum meum et amitam meam et Lydiam valere iubebo.",
      "spans": [
        {
          "start": 49,
          "end": 55,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Quam bellae fuerunt feriae a mane usque ad vesperum!",
      "spans": []
    },
    {
      "text": "Quae mutatio rerum instat!",
      "spans": []
    },
    {
      "text": "Pauci erunt dies feriati, multi profesti.",
      "spans": []
    }
  ],
