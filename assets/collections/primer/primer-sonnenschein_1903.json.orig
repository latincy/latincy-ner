          "end": 21,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Caledones in collibus suos collocaverant.",
      "spans": [
        {
          "start": 0,
          "end": 9,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Primo Caledones missilia Romanorum vitabant.",
