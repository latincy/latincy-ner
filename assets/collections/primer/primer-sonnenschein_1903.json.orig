{
  "metadata": {
    "title": "Pro patria: a Latin story for beginners, being a sequal to 'Ora Maritima', with grammar and exercises",
    "author": "Sonnenschein, E. A.",
    "date": "1903",
    "source": "https://archive.org/details/propatrialatinst00sonnrich",
    "latincy-ner-project": "primer",
    "latincy-ner-project-subset": "pro_patria",
    "license": "https://creativecommons.org/public-domain/cc0/"
  },
  "annotation": {
    "spacy_model": "la_core_web_lg",
    "spacy_model_version": "3.8.0",
    "tagset": [
      "PERSON",
      "LOC",
      "NORP"
    ],
    "annotators": [
      "Patrick J. Burns"
    ],
    "review_level": "silver"
  },
  "data": [
    {
      "text": "Kalendae sunt hodie Septembres.",
      "spans": []
    },
    {
      "text": "Primus mensis feriarum elapsus est, et scholae instant;",
      "spans": []
    },
    {
      "text": "nam ante finem mensis Septembris apud magistrum meum ero.",
      "spans": []
    },
    {
      "text": "Et per ultimam partem feriarum necesse est libris duas horas cotidie dare.",
      "spans": []
    },
    {
      "text": "Sic imperat patruus meus.",
      "spans": []
    },
    {
      "text": "Mane igitur plerumque lectito.",
      "spans": []
    },
    {
      "text": "Patruus autem mihi librum Taciti de vita Agricolae, ducis celebris Romanorum, dedit.",
      "spans": [
        {
          "start": 26,
          "end": 32,
          "label": "PERSON"
        },
        {
          "start": 41,
          "end": 50,
          "label": "PERSON"
        },
        {
          "start": 67,
          "end": 76,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Multa insunt de Britannia nostra antiqua.",
      "spans": [
        {
          "start": 16,
          "end": 25,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Vita Agricolae multum me delectat.",
      "spans": [
        {
          "start": 5,
          "end": 14,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Nonnullis tamen in locis difficilis est et obscura.",
      "spans": []
    },
    {
      "text": "Sed animo alacri lectito, quia patruus meus difficilia et obscura explicat, et tabulis pictis aedificiorum, armorum, nummorum, viarum illustrat.",
      "spans": []
    },
    {
      "text": "Ubi aliquid in Vita Agricolae deest, ibi patruus meus capita ex Annalibus Taciti vel ex Historia Anglica recitat.",
      "spans": [
        {
          "start": 20,
          "end": 29,
          "label": "PERSON"
        },
        {
          "start": 74,
          "end": 80,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Amici mei, Marcus et Alexander, interdum adsunt dum recitat;",
      "spans": [
        {
          "start": 11,
          "end": 17,
          "label": "PERSON"
        },
        {
          "start": 21,
          "end": 30,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "nam saepe nos visitant.",
      "spans": []
    },
    {
      "text": "Post prandium plerumque ambulamus, vel ludo trigonali operam damus, vel in mari natamus.",
      "spans": []
    },
    {
      "text": "Gaius Iulius Caesar, postquam copias suas pedestres et equestres ex Britannia in Galliam transportavit, nihil amplius de Britannis cogitavit.",
      "spans": [
        {
          "start": 0,
          "end": 19,
          "label": "PERSON"
        },
        {
          "start": 68,
          "end": 77,
          "label": "LOC"
        },
        {
          "start": 81,
          "end": 88,
          "label": "LOC"
        },
        {
          "start": 121,
          "end": 130,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Ab incolis litoris meridiani victoriam reportaverat, ad flumen Tamesam penetraverat, oppidum Cassivellauni expugnaverat, magnum numerum captivorum in servitutem venumdederat, tributum Britannis imperaverat.",
      "spans": [
        {
          "start": 63,
          "end": 70,
          "label": "LOC"
        },
        {
          "start": 93,
          "end": 106,
          "label": "PERSON"
        },
        {
          "start": 184,
          "end": 193,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Id ei satis erat.",
      "spans": []
    },
    {
      "text": "Sed Britanniam non revera debellaverat, nec victoria eius magna fuerat.",
      "spans": [
        {
          "start": 4,
          "end": 14,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Tacitus eum non magnam victoriam reportavisse in capite tertio decimo Vitae Agricolae affirmat.",
      "spans": [
        {
          "start": 0,
          "end": 7,
          "label": "PERSON"
        },
        {
          "start": 76,
          "end": 85,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "« Divus Iulius » inquit « Britanniam Romanis monstravit, sed non debellavit ».",
      "spans": [
        {
          "start": 2,
          "end": 16,
          "label": "PERSON"
        },
        {
          "start": 26,
          "end": 36,
          "label": "LOC"
        },
        {
          "start": 37,
          "end": 44,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Britanni autem viri animo forti erant.",
      "spans": [
        {
          "start": 0,
          "end": 8,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Tributum et servitutem non tolerabant.",
      "spans": []
    },
    {
      "text": "Et Romanis post tempora C. Iulii Caesaris longa oblivio erat Britanniae;",
      "spans": [
        {
          "start": 3,
          "end": 10,
          "label": "NORP"
        },
        {
          "start": 24,
          "end": 41,
          "label": "PERSON"
        },
        {
          "start": 61,
          "end": 71,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "nam per multos annos bellum domesticum civitatem Romanam vexavit.",
      "spans": [
        {
          "start": 49,
          "end": 56,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Post finem eius belli Romani Augustum principem creaverunt.",
      "spans": [
        {
          "start": 22,
          "end": 28,
          "label": "NORP"
        },
        {
          "start": 29,
          "end": 37,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Ei Britannia non curae erat.",
      "spans": [
        {
          "start": 3,
          "end": 12,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Nec principes secundus et tertius, Tiberius et Caligula, insulam nostram intraverunt;",
      "spans": [
        {
          "start": 35,
          "end": 43,
          "label": "PERSON"
        },
        {
          "start": 47,
          "end": 55,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "quamquam Caligula de ea intranda cogitavit.",
      "spans": [
        {
          "start": 9,
          "end": 17,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Itaque per centum fere annos reges Britannici vel reginae Britannicae in Britannia regnaverunt, nec Romani Britannos bello vexaverunt.",
      "spans": [
        {
          "start": 35,
          "end": 45,
          "label": "NORP"
        },
        {
          "start": 58,
          "end": 69,
          "label": "NORP"
        },
        {
          "start": 73,
          "end": 82,
          "label": "LOC"
        },
        {
          "start": 100,
          "end": 106,
          "label": "NORP"
        },
        {
          "start": 107,
          "end": 116,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "In numero eorum regum erat Cunobelinus.",
      "spans": [
        {
          "start": 27,
          "end": 38,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Is revera « Britannorum rex » erat:",
      "spans": [
        {
          "start": 12,
          "end": 23,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "sic eum Suetonius, scriptor Romanus, nominat;",
      "spans": [
        {
          "start": 8,
          "end": 17,
          "label": "PERSON"
        },
        {
          "start": 28,
          "end": 35,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "nam quamquam non omnes gentes Britannicae ei subiectae erant, tamen magnam partem gentium Britanniae mediterraneae et meridianae in unum regnum consociaverat.",
      "spans": [
        {
          "start": 30,
          "end": 41,
          "label": "NORP"
        },
        {
          "start": 90,
          "end": 100,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Caput earum gentium Camulodunum erat.",
      "spans": [
        {
          "start": 20,
          "end": 31,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Exstant hodie nummi Cunobelini;",
      "spans": [
        {
          "start": 20,
          "end": 30,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "in eis nomen regis vel litteras nonnullas eius nominis lectitare possumus:",
      "spans": []
    },
    {
      "text": "exstant quoque nummi patris eius Tasciovani et fratris eius Epaticci.",
      "spans": [
        {
          "start": 33,
          "end": 43,
          "label": "PERSON"
        },
        {
          "start": 60,
          "end": 68,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Cunobelinus multos annos regnavit;",
      "spans": [
        {
          "start": 0,
          "end": 11,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "eo fere tempore rex Britannorum erat, cum Tiberius et Caligula principes Romanorum erant.",
      "spans": [
        {
          "start": 20,
          "end": 31,
          "label": "NORP"
        },
        {
          "start": 42,
          "end": 50,
          "label": "PERSON"
        },
        {
          "start": 54,
          "end": 62,
          "label": "PERSON"
        },
        {
          "start": 73,
          "end": 82,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Ei ab anno quarto decimo ad annum primum et quadragesimum post Christum natum imperio Romano praeerant.",
      "spans": [
        {
          "start": 63,
          "end": 71,
          "label": "PERSON"
        },
        {
          "start": 86,
          "end": 92,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Iesus Christus natus erat dum Augustus princeps erat:",
      "spans": [
        {
          "start": 0,
          "end": 14,
          "label": "PERSON"
        },
        {
          "start": 30,
          "end": 38,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "morti datus erat dum Tiberius imperitabat, ut Tacitus in capite quarto et quadragesimo libri quinti decimi Annalium commemorat.",
      "spans": [
        {
          "start": 21,
          "end": 29,
          "label": "PERSON"
        },
        {
          "start": 46,
          "end": 53,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Inter filios Cunobelini erant Caractacus et Togodumnus.",
      "spans": [
        {
          "start": 13,
          "end": 23,
          "label": "PERSON"
        },
        {
          "start": 30,
          "end": 40,
          "label": "PERSON"
        },
        {
          "start": 44,
          "end": 54,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Is rex magnus et bonus erat, atque defensor acer libertatis Britannicae.",
      "spans": [
        {
          "start": 60,
          "end": 71,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sed Romani tantum regem tolerare non poterant.",
      "spans": [
        {
          "start": 4,
          "end": 10,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Itaque de nova expeditione contra Britanniam cogitabant.",
      "spans": [
        {
          "start": 34,
          "end": 44,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Poetae Romani eius aetatis insulam nostram et incolas eius saepe commemorant.",
      "spans": [
        {
          "start": 7,
          "end": 13,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Horatius eos « feros » et « remotos » et « intactos » (id est, « non debellatos » vel « liberos ») nominat;",
      "spans": [
        {
          "start": 0,
          "end": 8,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Vergilius eos « toto orbe terrarum divisos » (id est, « separatos ») vocat.",
      "spans": [
        {
          "start": 0,
          "end": 9,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Mare eos ab aliis partibus orbis terrarum separabat, et libertas eis cara erat.",
      "spans": []
    },
    {
      "text": "Pro aris et focis suis contra Romanos magna virtute pugnaverant, atque hostibus Romanorum in bello Gallico auxilia subministraverant.",
      "spans": [
        {
          "start": 30,
          "end": 37,
          "label": "NORP"
        },
        {
          "start": 80,
          "end": 89,
          "label": "NORP"
        },
        {
          "start": 99,
          "end": 106,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Itaque Romani libertatem eorum non tolerabant.",
      "spans": [
        {
          "start": 7,
          "end": 13,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Post mortem Cunobelini, Claudius, quartus princeps Romanorum, expeditionem contra Britannos paravit.",
      "spans": [
        {
          "start": 12,
          "end": 22,
          "label": "PERSON"
        },
        {
          "start": 24,
          "end": 32,
          "label": "PERSON"
        },
        {
          "start": 51,
          "end": 60,
          "label": "NORP"
        },
        {
          "start": 82,
          "end": 91,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Consilium eius erat totam Britanniam debellare et cum imperio Romano consociare.",
      "spans": [
        {
          "start": 26,
          "end": 36,
          "label": "LOC"
        },
        {
          "start": 62,
          "end": 68,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Itaque anno tertio et quadragesimo uni ex ducibus suis, Aulo Plautio, magnum numerum copiarum pedestrium et equestrium mandavit.",
      "spans": [
        {
          "start": 56,
          "end": 68,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Eae meridianam partem insulae nostrae facile occupaverunt.",
      "spans": []
    },
    {
      "text": "Oppidum Camulodunum expugnaverunt, ubi Romani post paucos annos coloniam veteranorum collocaverunt.",
      "spans": [
        {
          "start": 8,
          "end": 19,
          "label": "NORP"
        },
        {
          "start": 39,
          "end": 45,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Ea prima urbs Romana in Britannia fuit.",
      "spans": [
        {
          "start": 14,
          "end": 20,
          "label": "NORP"
        },
        {
          "start": 24,
          "end": 33,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Propter victoriam a Britannis reportatum princeps Romanus filio suo nomen Britannico dedit.",
      "spans": [
        {
          "start": 20,
          "end": 29,
          "label": "NORP"
        },
        {
          "start": 50,
          "end": 57,
          "label": "NORP"
        },
        {
          "start": 74,
          "end": 84,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Filius eius priore anno natus erat.",
      "spans": []
    },
    {
      "text": "Sed Britanni nondum debellati erant.",
      "spans": [
        {
          "start": 4,
          "end": 12,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "In silvas montesque Cambriae se occultaverant, ubi duae gentes bellicosae, Ordovices et Silures, per septem annos contra Romanos fortiter rebellaverunt.",
      "spans": [
        {
          "start": 20,
          "end": 28,
          "label": "LOC"
        },
        {
          "start": 75,
          "end": 84,
          "label": "NORP"
        },
        {
          "start": 88,
          "end": 95,
          "label": "NORP"
        },
        {
          "start": 121,
          "end": 128,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Copiis Britannicis Caractacus, filius Cunobelini, praeerat.",
      "spans": [
        {
          "start": 7,
          "end": 18,
          "label": "NORP"
        },
        {
          "start": 19,
          "end": 29,
          "label": "PERSON"
        },
        {
          "start": 38,
          "end": 48,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Nomen eius per totam Britanniam celebre erat.",
      "spans": [
        {
          "start": 21,
          "end": 31,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Non facile erat eas gentes Cambriae debellare.",
      "spans": [
        {
          "start": 27,
          "end": 35,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Reliquiae castrorum Romanorum Viroconii, Devae, Iscae hodie exstant.",
      "spans": [
        {
          "start": 20,
          "end": 29,
          "label": "NORP"
        },
        {
          "start": 30,
          "end": 39,
          "label": "LOC"
        },
        {
          "start": 41,
          "end": 46,
          "label": "LOC"
        },
        {
          "start": 48,
          "end": 53,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Sed legiones Romanae tandem victrices fuerunt, et Silures Ordovicesque magno proelio superaverunt.",
      "spans": [
        {
          "start": 13,
          "end": 20,
          "label": "NORP"
        },
        {
          "start": 50,
          "end": 57,
          "label": "NORP"
        },
        {
          "start": 58,
          "end": 67,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Deinde ducem eorum audacem et insignem Romam captivum deportaverunt.",
      "spans": [
        {
          "start": 39,
          "end": 44,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "ipse, ipsa, ipsum Nomen Caractaci iam per totam Italiam celebre erat;",
      "spans": [
        {
          "start": 24,
          "end": 33,
          "label": "PERSON"
        },
        {
          "start": 48,
          "end": 55,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "nam victoriam Romanorum per novem annos retardaverat.",
      "spans": [
        {
          "start": 14,
          "end": 23,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Et omnes homines cupidi erant regem Britannorum ipsum spectandi.",
      "spans": [
        {
          "start": 36,
          "end": 47,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Itaque Claudius populum ad grande spectaculum convocavit.",
      "spans": [
        {
          "start": 7,
          "end": 15,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Magna multitudo captivorum Britannicorum una cum Caractaco ipso et uxore fratribusque eius in catenis aderant.",
      "spans": [
        {
          "start": 27,
          "end": 40,
          "label": "NORP"
        },
        {
          "start": 49,
          "end": 58,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Tum ceteri captivi veniam principis imploraverunt.",
      "spans": []
    },
    {
      "text": "Sed Caractacus ipse animum audacem et vere Britannicum praestitit.",
      "spans": [
        {
          "start": 4,
          "end": 14,
          "label": "PERSON"
        },
        {
          "start": 43,
          "end": 54,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Ante oculos principis ipsius collocatus « Rex sum » inquit « et regibus claris oriundus:",
      "spans": []
    },
    {
      "text": "fuerunt mihi viri, equi, arma.",
      "spans": []
    },
    {
      "text": "Non mirum est si contra vos Romanos pro libertate pugnavi.",
      "spans": [
        {
          "start": 28,
          "end": 35,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Vos toti orbi terrarum imperitandi cupidi estis;",
      "spans": []
    },
    {
      "text": "sed nobis Britannis non mos est servitutem tolerare.",
      "spans": [
        {
          "start": 10,
          "end": 19,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Mortem non formido ».",
      "spans": []
    },
    {
      "text": "Tum princeps propter admirationem tantae audaciae veniam libertatemque Caractaco ipsi et uxori fratribusque eius dedit.",
      "spans": [
        {
          "start": 71,
          "end": 80,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Sic Tacitus in capite septimo et tricesimo libri duodecimi Annalium narrat.",
      "spans": [
        {
          "start": 4,
          "end": 11,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Anno post Christum natum primo et sexagesimo Britanni rebellaverunt.",
      "spans": [
        {
          "start": 10,
          "end": 18,
          "label": "PERSON"
        },
        {
          "start": 45,
          "end": 53,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Suetonius Paulinus, unus ex ducibus Neronis, quinti principis Romanorum, Britanniae tum praeerat.",
      "spans": [
        {
          "start": 0,
          "end": 18,
          "label": "PERSON"
        },
        {
          "start": 36,
          "end": 44,
          "label": "PERSON"
        },
        {
          "start": 62,
          "end": 71,
          "label": "NORP"
        },
        {
          "start": 73,
          "end": 83,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Ille in Monam insulam penetravit, ubi magnum numerum Druidarum trucidavit, et fana eorum vastavit.",
      "spans": [
        {
          "start": 8,
          "end": 13,
          "label": "LOC"
        },
        {
          "start": 53,
          "end": 62,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sed dum ille in Cambria abest, Iceni cum Cassis et Trinobantibus aliisque gentibus Britannicis se contra Romanos consociant.",
      "spans": [
        {
          "start": 16,
          "end": 23,
          "label": "LOC"
        },
        {
          "start": 31,
          "end": 36,
          "label": "NORP"
        },
        {
          "start": 41,
          "end": 47,
          "label": "NORP"
        },
        {
          "start": 51,
          "end": 64,
          "label": "NORP"
        },
        {
          "start": 83,
          "end": 94,
          "label": "NORP"
        },
        {
          "start": 105,
          "end": 112,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Non mirum est si Britanni coloniam illam Camulodunum, ubi veterani illi Romani collocati erant, non amabant.",
      "spans": [
        {
          "start": 17,
          "end": 25,
          "label": "NORP"
        },
        {
          "start": 41,
          "end": 52,
          "label": "LOC"
        },
        {
          "start": 72,
          "end": 78,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Nam veterani eos omnibus iniuriis vexabant.",
      "spans": []
    },
    {
      "text": "Uxores liberosque eorum in servitutem deportabant.",
      "spans": []
    },
    {
      "text": "Viros ipsos ignavos et servos vocabant.",
      "spans": []
    },
    {
      "text": "Oppidum iam viis et aedificiis Romanis ornaverunt, sed muris non firmaverant.",
      "spans": [
        {
          "start": 31,
          "end": 38,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Inter illa aedificia templum « Divi Claudii » erat;",
      "spans": [
        {
          "start": 36,
          "end": 43,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "nam principem mortuum Romani pro deo adorabant.",
      "spans": [
        {
          "start": 22,
          "end": 28,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Et in illo templo simulacrum Victoriae collocatum erat.",
      "spans": []
    },
    {
      "text": "Itaque Boadicea, regina illa audax Icenorum, inter ordines Britannicos in essedo suo equitans, Britannos suos ad rebellionem incitavit.",
      "spans": [
        {
          "start": 7,
          "end": 15,
          "label": "PERSON"
        },
        {
          "start": 35,
          "end": 43,
          "label": "NORP"
        },
        {
          "start": 59,
          "end": 70,
          "label": "NORP"
        },
        {
          "start": 95,
          "end": 104,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "« Auscultate » inquit, « Iceni et Cassi;",
      "spans": [
        {
          "start": 25,
          "end": 30,
          "label": "PERSON"
        },
        {
          "start": 34,
          "end": 39,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "auscultate Coritani, Trinobantes!",
      "spans": [
        {
          "start": 11,
          "end": 19,
          "label": "NORP"
        },
        {
          "start": 21,
          "end": 32,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Di nostri nobis victoriam, illis cladem mortemque parant!",
      "spans": []
    },
    {
      "text": "Ecce, colonia Camulodunum defensoribus nudata est!",
      "spans": [
        {
          "start": 14,
          "end": 25,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Copiae Romanae in finibus Ordovicum longe absunt, ubi fana Druidarum vastant.",
      "spans": [
        {
          "start": 7,
          "end": 14,
          "label": "NORP"
        },
        {
          "start": 26,
          "end": 35,
          "label": "NORP"
        },
        {
          "start": 59,
          "end": 68,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Coloniam illam, ubi pauci tantum veterani cum uxoribus liberisque suis habitant, facile erit expugnare.",
      "spans": []
    },
    {
      "text": "Illos nulla patria ad virtutem incitat;",
      "spans": []
    },
    {
      "text": "nos patria et penates, nos libertas ad arma vocat.",
      "spans": []
    },
    {
      "text": "Atque di ipsi nobis omen victoriae et imperii dederunt.",
      "spans": []
    },
    {
      "text": "Nam simulacrum illud Victoriae praecipitaverunt.",
      "spans": []
    },
    {
      "text": "Et Druidae alia portenta nuntiant.",
      "spans": [
        {
          "start": 3,
          "end": 10,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Terrae adhuc ignotae Britannis aliquando subiectae erunt.",
      "spans": [
        {
          "start": 21,
          "end": 30,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Ubi Caesares numquam steterunt, ibi filii nostri vel filii filiorum imperitabant.",
      "spans": [
        {
          "start": 4,
          "end": 12,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Vos coloniam illam crudelem expugnate!",
      "spans": []
    },
    {
      "text": "Templum dei illius falsi cremate!",
      "spans": []
    },
    {
      "text": "Viros, feminas, liberos trucidate!",
      "spans": []
    },
    {
      "text": "Illud est consilium feminae.",
      "spans": []
    },
    {
      "text": "Num vos viri minus fortes eritis? ».",
      "spans": []
    },
    {
      "text": "Britanni ad arma volant.",
      "spans": [
        {
          "start": 0,
          "end": 8,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Coloniam Camulodunum expugnant;",
      "spans": [
        {
          "start": 9,
          "end": 20,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "templum illud Claudii, ubi veterani se occultaverant, cremant.",
      "spans": [
        {
          "start": 14,
          "end": 21,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Interea Suetonius ex insula Mona cum decem milibus virorum ad Tamesam properavit.",
      "spans": [
        {
          "start": 8,
          "end": 17,
          "label": "PERSON"
        },
        {
          "start": 28,
          "end": 32,
          "label": "LOC"
        },
        {
          "start": 62,
          "end": 69,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Nam Londinium, quamquam nondum colonia Romana erat, tamen iam tum copia mercatorum et navigiorum celebre erat.",
      "spans": [
        {
          "start": 4,
          "end": 13,
          "label": "LOC"
        },
        {
          "start": 39,
          "end": 45,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sic Tacitus in capite tertio et tricesimo libri quarti decimi Annalium affirmat.",
      "spans": [
        {
          "start": 4,
          "end": 11,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Sed urbem ex clade servare non poterat.",
      "spans": []
    },
    {
      "text": "Britanni Londinium et Verulamium oppugnant, septuaginta milia Romanorum trucidant, ingentem praedam captant.",
      "spans": [
        {
          "start": 0,
          "end": 8,
          "label": "NORP"
        },
        {
          "start": 9,
          "end": 18,
          "label": "LOC"
        },
        {
          "start": 22,
          "end": 32,
          "label": "LOC"
        },
        {
          "start": 62,
          "end": 71,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Suetonius suos prope silvam collocaverat, et se ad proelium parabat.",
      "spans": [
        {
          "start": 0,
          "end": 9,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Britanni Romanos numero virorum multum superabant, et exspectatione victoriae triumpharunt.",
      "spans": [
        {
          "start": 0,
          "end": 8,
          "label": "NORP"
        },
        {
          "start": 9,
          "end": 16,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sed pauci illi Romani magnam victoriam reportaverunt;",
      "spans": [
        {
          "start": 15,
          "end": 21,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Britanni contra legiones Romanas stare non poterant, quia Romani eos pondere armorum et scientia belli multum superabant.",
      "spans": [
        {
          "start": 25,
          "end": 32,
          "label": "NORP"
        },
        {
          "start": 58,
          "end": 64,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "In illo proelio Romani octoginta milia virorum et feminarum trucidaverunt;",
      "spans": [
        {
          "start": 16,
          "end": 22,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "nam Britanni feminas suas in vehiculis apportaverunt, proelii spectandi causa.",
      "spans": [
        {
          "start": 4,
          "end": 12,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Boadicea ipsa se morti dedit.",
      "spans": [
        {
          "start": 0,
          "end": 8,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Hic fuit finis rebellionis Boadiceae.",
      "spans": [
        {
          "start": 27,
          "end": 36,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Sed Romani nondum totam insulam paraverant.",
      "spans": [
        {
          "start": 4,
          "end": 10,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Nam Britannia provincia turbulenta erat, ut Tacitus affirmat;",
      "spans": [
        {
          "start": 4,
          "end": 13,
          "label": "LOC"
        },
        {
          "start": 44,
          "end": 51,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "et Britanni occidentales et septentrionales victoriam Romanorum adhuc retardant.",
      "spans": [
        {
          "start": 3,
          "end": 11,
          "label": "NORP"
        },
        {
          "start": 54,
          "end": 63,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Totam insulam pacare consilium erat Vespasiani, noni principis Romanorum.",
      "spans": [
        {
          "start": 36,
          "end": 46,
          "label": "PERSON"
        },
        {
          "start": 63,
          "end": 72,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Itaque anno duodeoctogesimo post Christum natum Iulio Agricolae summum imperium legionum Britannicarum mandavit.",
      "spans": [
        {
          "start": 33,
          "end": 41,
          "label": "PERSON"
        },
        {
          "start": 48,
          "end": 63,
          "label": "PERSON"
        },
        {
          "start": 89,
          "end": 102,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Huius viri clari vitam Tacitus narravit.",
      "spans": [
        {
          "start": 23,
          "end": 30,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Uxor Taciti filia Agricolae erat.",
      "spans": [
        {
          "start": 5,
          "end": 11,
          "label": "PERSON"
        },
        {
          "start": 18,
          "end": 27,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Hunc virum Tacitus magnopere amabat, et memoriam eius monumento pulchro consecravit:",
      "spans": [
        {
          "start": 11,
          "end": 18,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "monumentum est liber ille de vita eius.",
      "spans": []
    },
    {
      "text": "Vir iustus, humanus, clemens erat, si testimonium Taciti verum est.",
      "spans": [
        {
          "start": 50,
          "end": 56,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Primo anno imperii sui Agricola in Cambria bellavit, ubi magnam victoriam ab Ordovicibus reportavit.",
      "spans": [
        {
          "start": 23,
          "end": 31,
          "label": "PERSON"
        },
        {
          "start": 35,
          "end": 42,
          "label": "LOC"
        },
        {
          "start": 77,
          "end": 88,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Hanc gentem fere totam trucidavit, si Tacitus vera affirmat.",
      "spans": [
        {
          "start": 38,
          "end": 45,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "Tum insulam Monam occupavit.",
      "spans": [
        {
          "start": 12,
          "end": 17,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Naves ei deerant;",
      "spans": []
    },
    {
      "text": "sed sub signis Romanis nonnullae cohortes Batavorum militabant.",
      "spans": [
        {
          "start": 15,
          "end": 22,
          "label": "NORP"
        },
        {
          "start": 42,
          "end": 51,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Hi periti erant natandi, et trans fretum nataverunt.",
      "spans": []
    },
    {
      "text": "Tertio anno Agricola contra Brigantes aliasque gentes septentrionales Britanniae bellavit.",
      "spans": [
        {
          "start": 12,
          "end": 20,
          "label": "PERSON"
        },
        {
          "start": 28,
          "end": 37,
          "label": "NORP"
        },
        {
          "start": 70,
          "end": 80,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sexto anno classem comparavit.",
      "spans": []
    },
    {
      "text": "Dum haec oram maritimam Caledoniae explorat, ipse cum copiis pedestribus et equestribus per Devam et Luguvallium in Caledoniam usque ad Clotam et Bodotriam penetrat.",
      "spans": [
        {
          "start": 24,
          "end": 34,
          "label": "LOC"
        },
        {
          "start": 92,
          "end": 97,
          "label": "LOC"
        },
        {
          "start": 101,
          "end": 112,
          "label": "LOC"
        },
        {
          "start": 116,
          "end": 126,
          "label": "LOC"
        },
        {
          "start": 136,
          "end": 142,
          "label": "LOC"
        },
        {
          "start": 146,
          "end": 155,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Totam regionem castellis firmat.",
      "spans": []
    },
    {
      "text": "Sed Caledonii trans Clotam et Bodotriam, velut in alteram insulam, se congregant.",
      "spans": [
        {
          "start": 4,
          "end": 13,
          "label": "NORP"
        },
        {
          "start": 20,
          "end": 26,
          "label": "LOC"
        },
        {
          "start": 30,
          "end": 39,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Proximo anno Romani in partes interiores Caledoniae penetrant.",
      "spans": [
        {
          "start": 13,
          "end": 19,
          "label": "NORP"
        },
        {
          "start": 41,
          "end": 51,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Ibi, prope Montem Graupium, dux Caledonius, Galgacus vel Calgacus nomine, suos ad proelium his verbis incitat.",
      "spans": [
        {
          "start": 11,
          "end": 26,
          "label": "LOC"
        },
        {
          "start": 32,
          "end": 42,
          "label": "PERSON"
        },
        {
          "start": 44,
          "end": 52,
          "label": "PERSON"
        },
        {
          "start": 57,
          "end": 65,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "« Haec pugna, ut spero, causa libertatis perpetuae totae Britanniae erit.",
      "spans": [
        {
          "start": 57,
          "end": 67,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Nobis Caledonibus servitus adhuc ignota est.",
      "spans": [
        {
          "start": 6,
          "end": 17,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Hi montes, hae silvae, haec maria nobis libertatem dederunt.",
      "spans": []
    },
    {
      "text": "Sed nunc in hunc angulum remotum Britanniae Romani penetraverunt.",
      "spans": [
        {
          "start": 33,
          "end": 43,
          "label": "LOC"
        },
        {
          "start": 44,
          "end": 50,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Adsunt, velut lupi saevi;",
      "spans": []
    },
    {
      "text": "nec Oriens nec Occidens eos satiavit.",
      "spans": []
    },
    {
      "text": "Ne mare quidem nostrum a periculo classis Romanae tutum est.",
      "spans": [
        {
          "start": 42,
          "end": 49,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Terra marique hanc insulam oppugnant.",
      "spans": []
    },
    {
      "text": "Itaque nullam veniam exspectate, si illi in hoc proelio victoriam reportaverint.",
      "spans": []
    },
    {
      "text": "Vos ipsos et uxores liberosque vestros trucidabunt vel in servitutem deportabunt;",
      "spans": []
    },
    {
      "text": "et cum totam terram vastaverint, solitudinem pacem vocabunt.",
      "spans": []
    },
    {
      "text": "Sed nondum \"pacata\" est haec Caledonia.",
      "spans": [
        {
          "start": 29,
          "end": 38,
          "label": "LOC"
        }
      ]
    },
    {
      "text": "Iceni et Trinobantes coloniam Romanam expugnaverunt et cremaverunt.",
      "spans": [
        {
          "start": 0,
          "end": 5,
          "label": "NORP"
        },
        {
          "start": 9,
          "end": 20,
          "label": "NORP"
        },
        {
          "start": 30,
          "end": 37,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Femina facinoris illius praeclari dux erat.",
      "spans": []
    },
    {
      "text": "Num vos, viri Caledonii, minus fortes eritis?",
      "spans": [
        {
          "start": 14,
          "end": 23,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Hodie pacem illam Romanam a vobis ipsis et uxoribus liberisque vestris propulsate.",
      "spans": [
        {
          "start": 18,
          "end": 25,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Patria ipsa vos ad pugnam et victoriam vocat! » Interea Agricola quoque suos in hunc modum ad proelium incitat.",
      "spans": [
        {
          "start": 56,
          "end": 64,
          "label": "PERSON"
        }
      ]
    },
    {
      "text": "« Hic septimus est annus, milites, postquam Ordovices debellavistis.",
      "spans": [
        {
          "start": 44,
          "end": 53,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Hodie a Caledonibus victoriam reportate.",
      "spans": [
        {
          "start": 8,
          "end": 19,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Hi se in silvis montibusque suis adhuc occultaverunt;",
      "spans": []
    },
    {
      "text": "hos homines ignavos facile in fugam dabitis ».",
      "spans": []
    },
    {
      "text": "Et signum pugnandi dedit.",
      "spans": []
    },
    {
      "text": "Tres legiones Romanae et undecim milia auxiliorum in campo lato stabant:",
