          "label": "NORP"
        }
      ]
    },
    {
      "text": "Et ipsi multa missilia in Romanos iactabant.",
      "spans": [
        {
          "start": 26,
          "end": 33,
          "label": "NORP"
        }
      ]
    },
    {
      "text": "Sed tandem cohortes illae Batavorum ad colles appropinquaverunt, et Caledones ex loco propulsaverunt.",
