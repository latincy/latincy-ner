    {
      "text": "Interea equites auxiliorum eos velut indagine circumdederunt.",
      "spans": []
    },
    {
      "text": "Decem milia trucidaverunt vel vulneraverunt.",
      "spans": []
    },
    {
      "text": "Nonnulli ex Caledonibus uxores liberosque suos ipsi morti dederunt.",
      "spans": [
